<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Tax Invoice - <%= data.invoice.invoice_no %></title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 12px;
            color: #222;
            background: #fff;
        }

        .page {
            width: 100%;
            padding: 18px 20px;
        }

        /* ── TOP HEADER BAR ── */
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #999;
            border-bottom: none;
            padding: 6px 12px;
            background: #f9f9f9;
        }

        .top-header .title {
            font-size: 15px;
            font-weight: bold;
            letter-spacing: 3px;
            text-transform: uppercase;
            text-align: center;
            flex: 1;
        }

        .top-header .copy-label {
            font-size: 11px;
            font-weight: bold;
            color: #444;
            white-space: nowrap;
        }

        /* ── SELLER + INVOICE META ROW ── */
        .info-row {
            display: flex;
            border: 1px solid #999;
            border-bottom: none;
        }

        .seller-block {
            flex: 0 0 45%;
            padding: 10px 12px;
            border-right: 1px solid #999;
        }

        .seller-block .company-name {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 2px;
        }

        .seller-block .gst-line {
            font-size: 11px;
            font-weight: bold;
            color: #333;
            margin-bottom: 4px;
        }

        .seller-block .address-line {
            font-size: 11px;
            color: #444;
            line-height: 1.5;
        }

        .invoice-meta-block {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .meta-half {
            flex: 1;
            display: flex;
            border-bottom: 1px solid #999;
        }

        .meta-half:last-child {
            border-bottom: none;
        }

        .meta-cell {
            flex: 1;
            padding: 7px 10px;
            border-right: 1px solid #999;
            font-size: 11px;
        }

        .meta-cell:last-child {
            border-right: none;
        }

        .meta-cell .cell-label {
            color: #666;
            font-size: 10px;
            margin-bottom: 2px;
        }

        .meta-cell .cell-value {
            font-weight: bold;
            font-size: 12px;
        }

        /* ── BUYER + SHIPPING ROW ── */
        .address-row {
            display: flex;
            border: 1px solid #999;
            margin-bottom: 5px;
        }

        .buyer-block {
            flex: 0 0 45%;
            padding: 10px 12px;
            border-right: 1px solid #999;
            font-size: 11px;
            line-height: 1.6;
        }

        .buyer-block .block-label {
            font-weight: bold;
            font-size: 11px;
            margin-bottom: 3px;
        }

        .buyer-block .buyer-name {
            font-size: 13px;
            font-weight: bold;
            margin-bottom: 2px;
        }

        .shipping-block {
            flex: 1;
            padding: 10px 12px;
            font-size: 11px;
            line-height: 1.6;
        }

        .shipping-block .block-label {
            font-weight: bold;
            font-size: 11px;
            margin-bottom: 3px;
        }

        /* ── ITEMS TABLE ── */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            border: 1px solid #999;
            margin-bottom: 5px;
        }

        .items-table th,
        .items-table td {
            border: 1px solid #bbb;
            padding: 6px 7px;
            font-size: 11px;
            vertical-align: top;
        }

        .items-table thead tr {
            background: #f0f0f0;
        }

        .items-table th {
            font-weight: bold;
            text-align: center;
            font-size: 11px;
        }

        .items-table td.center {
            text-align: center;
        }

        .items-table td.right {
            text-align: right;
        }

        .items-table .product-name {
            font-weight: bold;
        }

        .items-table .product-sub {
            font-size: 10px;
            color: #555;
        }

        /* ── TOTALS FOOTER ── */
        .totals-row {
            display: flex;
            border: 1px solid #999;
            border-bottom: none;
        }

        .totals-label-col {
            flex: 0 0 45%;
            padding: 6px 10px;
            font-size: 11px;
            border-right: 1px solid #999;
        }

        .totals-amount-col {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .total-line {
            width: 100%;
            display: flex;
            justify-content: space-between;
            padding: 5px 12px;
            font-size: 12px;
            border-bottom: 1px solid #ddd;
        }

        .total-line:last-child {
            border-bottom: none;
        }

        .total-line.grand {
            font-weight: bold;
            font-size: 14px;
            background: #f9f9f9;
        }

        .total-line .tl-label {
            color: #444;
        }

        .total-line .tl-value {
            font-weight: bold;
        }

        /* ── AMOUNT IN WORDS ── */
        .amount-words-row {
            border: 1px solid #999;
            border-bottom: none;
            padding: 6px 12px;
            font-size: 11px;
        }

        /* ── HSN SUMMARY TABLE ── */
        .hsn-table-wrapper {
            border: 1px solid #999;
            border-bottom: none;
        }

        .hsn-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }

        .hsn-table th,
        .hsn-table td {
            border: 1px solid #bbb;
            padding: 5px 8px;
            text-align: right;
        }

        .hsn-table thead tr {
            background: #f0f0f0;
        }

        .hsn-table th {
            font-weight: bold;
            text-align: center;
        }

        .hsn-table td:first-child,
        .hsn-table th:first-child {
            text-align: left;
        }

        .hsn-table .total-row td {
            font-weight: bold;
            background: #fafafa;
        }

        /* ── AMOUNT PAID BADGE ── */
        .paid-badge-row {
            border: 1px solid #999;
            border-bottom: none;
            display: flex;
            justify-content: flex-end;
            padding: 5px 12px;
        }

        .paid-badge {
            background: #e6f4ea;
            color: #1e7e34;
            border: 1px solid #a8d5b5;
            border-radius: 4px;
            padding: 3px 14px;
            font-size: 11px;
            font-weight: bold;
        }

        /* ── FOOTER SECTION (Signature) ── */
        .footer-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            border: 1px solid #999;
            border-bottom: none;
            padding: 14px 16px;
            min-height: 90px;
        }

        /* kept in CSS for future re-enable */
        .bank-block { display: none; }
        .upi-block  { display: none; }
        .qr-placeholder { display: none; }

        .sign-block {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            font-size: 11px;
            min-width: 180px;
        }

        .sign-block .sign-for {
            font-weight: bold;
            font-size: 11px;
            margin-bottom: 36px;
        }

        .sign-box {
            width: 160px;
            border-top: 1px solid #666;
            padding-top: 5px;
            font-size: 10px;
            color: #555;
            text-align: center;
        }

        /* ── NOTES + TERMS ── */
        .notes-terms-row {
            display: flex;
            border: 1px solid #999;
            border-bottom: none;
        }

        .notes-block {
            flex: 0 0 38%;
            padding: 10px 12px;
            border-right: 1px solid #999;
            font-size: 11px;
        }

        .notes-block .block-title {
            font-weight: bold;
            margin-bottom: 5px;
        }

        .terms-block {
            flex: 1;
            padding: 10px 12px;
            font-size: 11px;
        }

        .terms-block .block-title {
            font-weight: bold;
            margin-bottom: 5px;
        }

        .terms-block ol {
            padding-left: 15px;
            line-height: 1.7;
        }

        /* ── PAGE FOOTER ── */
        .page-footer {
            border: 1px solid #999;
            padding: 6px 12px;
            font-size: 10px;
            color: #555;
            display: flex;
            justify-content: space-between;
        }
    </style>
</head>

<body>
    <%
        /* ── Destructure from the `data` wrapper passed by pdf.service.js ── */
        const invoice         = data.invoice;
        const sellerDetails   = data.sellerDetails;
        const customerDetails = data.customerDetails;

        /* ── Helpers ── */
        function fmtDate(d) {
            if (!d) return '-';
            return new Date(d).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
        }
        function fmtNum(n) {
            return Number(n).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        /* Resolve state name safely */
        function addrState(addr) {
            if (!addr) return '';
            if (addr.state && addr.state.name) return addr.state.name;
            return '';
        }

        /* Simple number-to-words (INR) */
        const ones = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine',
                       'Ten','Eleven','Twelve','Thirteen','Fourteen','Fifteen','Sixteen',
                       'Seventeen','Eighteen','Nineteen'];
        const tens = ['','','Twenty','Thirty','Forty','Fifty','Sixty','Seventy','Eighty','Ninety'];

        function numToWords(n) {
            n = Math.floor(Number(n));
            if (n === 0) return 'Zero';
            let str = '';
            if (n >= 10000000) { str += numToWords(Math.floor(n / 10000000)) + ' Crore '; n %= 10000000; }
            if (n >= 100000)   { str += numToWords(Math.floor(n / 100000))   + ' Lakh ';  n %= 100000;  }
            if (n >= 1000)     { str += numToWords(Math.floor(n / 1000))     + ' Thousand '; n %= 1000; }
            if (n >= 100)      { str += numToWords(Math.floor(n / 100))      + ' Hundred ';  n %= 100;  }
            if (n >= 20)       { str += tens[Math.floor(n / 10)];
                                 if (n % 10) str += ' ' + ones[n % 10];
            } else if (n > 0)  { str += ones[n]; }
            return str.trim();
        }

        function amountInWords(amount) {
            const total = Number(amount);
            const rupees = Math.floor(total);
            const paise  = Math.round((total - rupees) * 100);
            let words = 'INR ' + numToWords(rupees) + ' Rupees';
            if (paise > 0) words += ' And ' + numToWords(paise) + ' Paise';
            words += ' Only';
            return words;
        }

        /* Determine tax label from tax_type */
        const isInter = (invoice.tax_type || '').toLowerCase() === 'inter';
        const taxLabel = isInter ? 'IGST' : 'CGST + SGST';

        /* HSN summary aggregation */
        const hsnMap = {};
        invoice.invoiceItems.forEach(item => {
            const key = item.hsn_code || '-';
            if (!hsnMap[key]) {
                hsnMap[key] = { taxableValue: 0, rate: Number(item.tax_rate), taxAmount: 0 };
            }
            hsnMap[key].taxableValue += Number(item.itemLevel_sub_total);
            hsnMap[key].taxAmount    += Number(item.tax_amount);
        });
        const hsnRows = Object.entries(hsnMap);

        /* Total items count & qty */
        const totalQty = invoice.invoiceItems.reduce((s, i) => s + Number(i.qty), 0);
    %>

    <div class="page">

        <!-- ── TOP HEADER BAR ── -->
        <div class="top-header">
            <span class="title">Tax &nbsp; Invoice</span>
            <span class="copy-label">ORIGINAL FOR RECIPIENT</span>
        </div>

        <!-- ── SELLER + INVOICE META ── -->
        <div class="info-row">
            <div class="seller-block">
                <div class="company-name"><%= sellerDetails.name %></div>
                <div class="gst-line">GSTIN <%= sellerDetails.gst_no || 'N/A' %></div>
                <div class="address-line">
                    <% if (sellerDetails.address) { %>
                        <%= sellerDetails.address.address || '' %><% if (sellerDetails.address.district && sellerDetails.address.district.name) { %>, <%= sellerDetails.address.district.name %><% } %><br/>
                        <%= addrState(sellerDetails.address) %><br/>
                        <% if (sellerDetails.license_no) { %>Lic. No: <%= sellerDetails.license_no %><br/><% } %>
                    <% } %>
                    Location: <%= sellerDetails.location || '' %>
                </div>
            </div>

            <div class="invoice-meta-block">
                <div class="meta-half">
                    <div class="meta-cell">
                        <div class="cell-label">Invoice #:</div>
                        <div class="cell-value"><%= invoice.invoice_no %></div>
                    </div>
                    <div class="meta-cell">
                        <div class="cell-label">Invoice Date:</div>
                        <div class="cell-value"><%= fmtDate(invoice.invoice_date) %></div>
                    </div>
                </div>
                <div class="meta-half">
                    <div class="meta-cell">
                        <div class="cell-label">Place of Supply:</div>
                        <div class="cell-value"><%= addrState(sellerDetails.address) || '-' %></div>
                    </div>
                    <div class="meta-cell">
                        <div class="cell-label">Tax Type:</div>
                        <div class="cell-value"><%= (invoice.tax_type || '-').toUpperCase() %></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── BUYER + SHIPPING ADDRESS ── -->
        <div class="address-row">
            <div class="buyer-block">
                <div class="block-label">Customer Details:</div>
                <div class="buyer-name"><%= customerDetails.name %></div>
                <div><strong>Billing address:</strong></div>
                <% if (customerDetails.address) { %>
                    <%= customerDetails.address.address || '' %><br/>
                    <% if (customerDetails.address.district && customerDetails.address.district.name) { %><%= customerDetails.address.district.name %><br/><% } %>
                    <%= addrState(customerDetails.address) %><br/>
                <% } %>
                GSTIN: <%= customerDetails.gst_no || 'N/A' %><br/>
                Lic. No: <%= customerDetails.license_no || 'N/A' %>
            </div>

            <div class="shipping-block">
                <div class="block-label">Shipping address:</div>
                <% if (customerDetails.address) { %>
                    <%= customerDetails.address.address || '' %><br/>
                    <% if (customerDetails.address.district && customerDetails.address.district.name) { %><%= customerDetails.address.district.name %><br/><% } %>
                    <%= addrState(customerDetails.address) %>
                    <% if (customerDetails.location) { %>, <%= customerDetails.location %><% } %>
                <% } %>
            </div>
        </div>

        <!-- ── LINE ITEMS TABLE ── -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:4%">#</th>
                    <th style="width:22%">Item</th>
                    <th style="width:9%">HSN/SAC</th>
                    <th style="width:9%">Batch No.</th>
                    <th style="width:8%">Mfg Date</th>
                    <th style="width:8%">Exp Date</th>
                    <th style="width:10%">Rate / Item</th>
                    <th style="width:6%">Qty</th>
                    <th style="width:11%">Taxable Value</th>
                    <th style="width:13%">Tax Amount</th>
                    <th style="width:10%">Amount</th>
                </tr>
            </thead>
            <tbody>
                <% invoice.invoiceItems.forEach(function(item, idx) { %>
                <tr>
                    <td class="center"><%= idx + 1 %></td>
                    <td>
                        <div class="product-name"><%= item.seller_product_name %></div>
                        <div class="product-sub">SKU: <%= item.seller_product_sku %></div>
                        <% if (item.buyer_product_name && item.buyer_product_name !== item.seller_product_name) { %>
                        <div class="product-sub">Buyer: <%= item.buyer_product_name %> (<%= item.buyer_product_sku %>)</div>
                        <% } %>
                    </td>
                    <td class="center"><%= item.hsn_code || '-' %></td>
                    <td class="center"><%= item.batch_no || '-' %></td>
                    <td class="center"><%= fmtDate(item.mfg_date) %></td>
                    <td class="center"><%= fmtDate(item.expiry_date) %></td>
                    <td class="right"><%= fmtNum(item.unit_price) %></td>
                    <td class="center"><%= fmtNum(item.qty) %></td>
                    <td class="right"><%= fmtNum(item.itemLevel_sub_total) %></td>
                    <td class="right"><%= fmtNum(item.tax_amount) %> (<%= Number(item.tax_rate).toFixed(0) %>%)</td>
                    <td class="right"><%= fmtNum(item.itemLevel_grand_total) %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <!-- ── TOTALS ROW ── -->
        <div class="totals-row">
            <div class="totals-label-col">
                Total Items / Qty : <%= invoice.invoiceItems.length %> / <%= fmtNum(totalQty) %>
            </div>
            <div class="totals-amount-col">
                <div class="total-line">
                    <span class="tl-label">Taxable Amount</span>
                    <span class="tl-value">₹<%= fmtNum(invoice.sub_total) %></span>
                </div>
                <div class="total-line">
                    <span class="tl-label"><%= taxLabel %></span>
                    <span class="tl-value">₹<%= fmtNum(invoice.total_tax_amount) %></span>
                </div>
                <% if (Number(invoice.discount) > 0) { %>
                <div class="total-line">
                    <span class="tl-label">Discount</span>
                    <span class="tl-value">- ₹<%= fmtNum(invoice.discount) %></span>
                </div>
                <% } %>
                <div class="total-line grand">
                    <span class="tl-label">Total</span>
                    <span class="tl-value">₹<%= fmtNum(invoice.grand_total) %></span>
                </div>
            </div>
        </div>

        <!-- ── AMOUNT IN WORDS ── -->
        <div class="amount-words-row">
            <strong>Total amount (in words):</strong> <%= amountInWords(invoice.grand_total) %>
        </div>

        <!-- ── HSN / TAX SUMMARY TABLE ── -->
        <div class="hsn-table-wrapper">
            <table class="hsn-table">
                <thead>
                    <tr>
                        <th>HSN/SAC</th>
                        <th>Taxable Value</th>
                        <th colspan="2"><%= isInter ? 'Integrated Tax' : 'Central Tax' %></th>
                        <th>Total Tax Amount</th>
                    </tr>
                    <tr>
                        <th></th>
                        <th></th>
                        <th>Rate</th>
                        <th>Amount</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% hsnRows.forEach(function([hsn, row]) { %>
                    <tr>
                        <td><%= hsn %></td>
                        <td><%= fmtNum(row.taxableValue) %></td>
                        <td><%= row.rate %>%</td>
                        <td><%= fmtNum(row.taxAmount) %></td>
                        <td><%= fmtNum(row.taxAmount) %></td>
                    </tr>
                    <% }) %>
                    <tr class="total-row">
                        <td>TOTAL</td>
                        <td><%= fmtNum(invoice.sub_total) %></td>
                        <td></td>
                        <td><%= fmtNum(invoice.total_tax_amount) %></td>
                        <td><%= fmtNum(invoice.total_tax_amount) %></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- ── AMOUNT PAID BADGE ── -->
        <!-- <div class="paid-badge-row">
            <span class="paid-badge">✔ Amount Paid</span>
        </div> -->

        <!-- ── FOOTER: SIGNATURE ── -->
        <div class="footer-row">

            <!-- ── BANK DETAILS (disabled — uncomment to re-enable)
            <div class="bank-block">
                <div class="block-title">Bank Details:</div>
                <div class="bank-row"><span class="bank-key">Bank:</span><span class="bank-val">-</span></div>
                <div class="bank-row"><span class="bank-key">Account #:</span><span class="bank-val">-</span></div>
                <div class="bank-row"><span class="bank-key">IFSC:</span><span class="bank-val">-</span></div>
                <div class="bank-row"><span class="bank-key">Branch:</span><span class="bank-val">-</span></div>
            </div>
            ──────────────────────── -->

            <!-- ── PAY USING UPI (disabled — uncomment to re-enable)
            <div class="upi-block">
                <div class="block-title">Pay using UPI:</div>
                <div class="qr-placeholder">QR Code</div>
            </div>
            ──────────────────────── -->

            <!-- Spacer so signature stays right-aligned -->
            <div></div>

            <div class="sign-block">
                <div class="sign-for">For <%= sellerDetails.name %></div>
                <div class="sign-box">Authorized Signatory</div>
            </div>
        </div>

        <!-- ── NOTES + TERMS ── -->
        <div class="notes-terms-row">
            <div class="notes-block">
                <div class="block-title">Notes:</div>
                Thank you for the Business
            </div>
            <div class="terms-block">
                <div class="block-title">Terms and Conditions:</div>
                <ol>
                    <li>Goods once sold cannot be taken back or exchanged.</li>
                    <li>We are not the manufacturers, company will stand for warranty as per their terms and conditions.</li>
                    <li>Interest @24% p.a. will be charged for uncleared bills beyond 15 days.</li>
                    <li>Subject to local Jurisdiction.</li>
                </ol>
            </div>
        </div>

        <!-- ── PAGE FOOTER ── -->
        <div class="page-footer">
            <span>Page 1 / 1</span>
            <span>This is a digitally signed document.</span>
        </div>

    </div>
</body>

</html>
