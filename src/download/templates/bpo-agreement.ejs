<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>BPO Agreement - <%= data.bpo_no %></title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 12px;
            color: #222;
            line-height: 1.5;
        }

        .container {
            width: 100%;
            padding: 28px 32px;
        }

        /* ── Header ── */
        .doc-header {
            text-align: center;
            border-bottom: 3px solid #1a3c6e;
            padding-bottom: 16px;
            margin-bottom: 20px;
        }

        /* ── Watermark ── */
        .watermark {
            position: fixed;
            top: 55%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 380px;
            height: 380px;
            opacity: 0.175;
            z-index: -1000;
            pointer-events: none;
        }

        .doc-header h1 {
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 1px;
            color: #1a3c6e;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .meta-bar {
            display: flex;
            justify-content: center;
            gap: 32px;
            font-size: 11px;
            color: #444;
        }

        .meta-bar span strong {
            color: #222;
        }

        /* ── Status Badge ── */
        .status-badge {
            display: inline-block;
            padding: 3px 12px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            vertical-align: middle;
        }

        .status-active {
            background: #e6f4ea;
            color: #1e7e34;
            border: 1px solid #b7dfbf;
        }

        .status-inactive,
        .status-expired {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        .status-draft {
            background: #fff3cd;
            color: #856404;
            border: 1px solid #ffc107;
        }

        /* ── Parties Section ── */
        .party-section {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .party-box {
            flex: 1;
            border: 1px solid #c8d4e8;
            border-radius: 6px;
            padding: 14px 16px;
            background: #f7f9fd;
        }

        .party-box-title {
            font-weight: bold;
            font-size: 10px;
            text-transform: uppercase;
            color: #1a3c6e;
            letter-spacing: 0.6px;
            margin-bottom: 8px;
            border-bottom: 1px solid #d0daf0;
            padding-bottom: 5px;
        }

        .party-name {
            font-size: 14px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 3px;
        }

        .party-meta {
            font-size: 11px;
            color: #555;
            margin-top: 2px;
        }

        .party-meta strong {
            color: #333;
        }

        /* ── Section Titles ── */
        .section-title {
            font-size: 12px;
            font-weight: bold;
            color: #1a3c6e;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-left: 4px solid #1a3c6e;
            padding-left: 8px;
            margin-bottom: 10px;
            margin-top: 20px;
        }

        /* ── Scope Paragraph ── */
        .scope-paragraph {
            font-size: 12px;
            color: #333;
            line-height: 1.7;
            border: 1px solid #dde5f5;
            border-radius: 4px;
            padding: 12px 14px;
            /* background: #fafbff; */
        }

        /* ── Items Table ── */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
            page-break-inside: avoid;
        }

        .items-table th,
        .items-table td {
            border: 1px solid #d6dff0;
            padding: 9px 10px;
            text-align: left;
            font-size: 11px;
            vertical-align: top;
        }

        .items-table th {
            background: #1a3c6e;
            color: #fff;
            font-weight: bold;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .items-table tbody tr:nth-child(even) {
            background: #f4f7fd;
        }

        .items-table .right {
            text-align: right;
        }

        .items-table .center {
            text-align: center;
        }

        .product-name {
            font-weight: 600;
            color: #1a1a1a;
        }

        .product-buyer-sku {
            font-size: 10px;
            color: #555;
            margin-top: 2px;
        }

        .product-vendor-ref {
            font-size: 10px;
            color: #1a6e44;
            margin-top: 3px;
            padding-top: 3px;
            border-top: 1px dashed #c5d8c8;
        }

        /* Grand Total Row */
        .items-table .grand-total-row td {
            background: #1a3c6e;
            color: #fff;
            font-weight: bold;
            font-size: 12px;
            border-color: #1a3c6e;
        }

        /* ── Terms & Conditions ── */
        .terms-list {
            margin: 0;
            padding-left: 20px;
            line-height: 1.8;
        }

        .terms-list li {
            margin-bottom: 8px;
            font-size: 12px;
            color: #333;
        }

        .terms-list li strong {
            color: #1a3c6e;
        }

        /* ── Signature Block ── */
        .signature-section {
            page-break-inside: avoid;
            margin-top: 30px;
        }

        .signature-note {
            font-size: 11px;
            color: #555;
            font-style: italic;
            border-left: 3px solid #ccc;
            padding-left: 10px;
            margin-bottom: 30px;
        }

        .signature-row {
            display: flex;
            justify-content: space-between;
            gap: 40px;
        }

        .signature-block {
            flex: 1;
            border: 1px solid #c8d4e8;
            border-radius: 6px;
            padding: 14px 16px;
        }

        .signature-block-title {
            font-size: 11px;
            font-weight: bold;
            color: #1a3c6e;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }

        .signature-line {
            height: 56px;
            border-bottom: 1px solid #999;
            margin-bottom: 8px;
        }

        .signature-label {
            font-size: 10px;
            color: #666;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-bottom: 4px;
        }

        .signature-field {
            font-size: 11px;
            color: #333;
            border-bottom: 1px dotted #ccc;
            padding-bottom: 3px;
            margin-top: 6px;
            min-height: 18px;
        }

        /* ── Footer ── */
        .doc-footer {
            margin-top: 36px;
            border-top: 2px solid #1a3c6e;
            padding-top: 10px;
            text-align: center;
            font-size: 10px;
            color: #888;
        }

        /* ── Reference Row ── */
        .ref-bar {
            display: flex;
            gap: 0;
            border: 1px solid #dde5f5;
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .ref-cell {
            flex: 1;
            padding: 8px 12px;
            border-right: 1px solid #dde5f5;
            font-size: 11px;
        }

        .ref-cell:last-child {
            border-right: none;
        }

        .ref-cell .ref-label {
            font-size: 10px;
            color: #888;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-bottom: 3px;
        }

        .ref-cell .ref-value {
            color: #1a3c6e;
            font-weight: 600;
        }
    </style>
</head>

<body>
    <%
        /* ── Derived data helpers ── */
        const firstItem = data.blanketOrderItems && data.blanketOrderItems[0];
        const buyer  = firstItem ? firstItem.buyerDetails  : null;
        const vendor = firstItem ? firstItem.vendorDetails : null;

        const buyerNode  = buyer  ? buyer.nodeDetails  : null;
        const vendorNode = vendor ? vendor.nodeDetails : null;

        const buyerAddress  = buyerNode  && buyerNode.address  ? buyerNode.address  : null;
        const vendorAddress = vendorNode && vendorNode.address ? vendorNode.address : null;

        function fmtDate(d) {
            if (!d) return '-';
            return new Date(d).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });
        }

        function fmtCurrency(n) {
            return Number(n || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        let grandTotal = 0;
        data.blanketOrderItems.forEach(function(item) {
            grandTotal += Number(item.total_contracted_qty || 0) * Number(item.unit_price || 0);
        });
    %>

    <% if (data.watermarkLogo) { %>
        <img class="watermark" src="<%= data.watermarkLogo %>" alt="" />
    <% } %>

    <div class="container">

        <!-- ══ HEADER ══ -->
        <div class="doc-header">
            <h1>Blanket Purchase Order (BPO) Agreement</h1>

            <div class="meta-bar">
                <span><strong>BPO No:</strong> <%= data.bpo_no %></span>
                <span><strong>Date of Agreement:</strong> <%= fmtDate(data.createdAt) %></span>
                <span><strong>Contract Validity:</strong>
                    <%= fmtDate(data.createdAt) %> &nbsp;to&nbsp; <%= fmtDate(data.valid_until) %>
                </span>
                <span>
                    <span class="status-badge status-<%= data.status %>">
                        <%= data.status ? data.status.toUpperCase() : '-' %>
                    </span>
                </span>
            </div>
        </div>


        <!-- ══ REFERENCE BAR ══ -->
        <div class="ref-bar">
            <div class="ref-cell">
                <div class="ref-label">BPO Number</div>
                <div class="ref-value"><%= data.bpo_no %></div>
            </div>
            <div class="ref-cell">
                <div class="ref-label">PR Reference</div>
                <div class="ref-value"><%= data.pr_reference_code || '-' %></div>
            </div>
            <div class="ref-cell">
                <div class="ref-label">Valid Until</div>
                <div class="ref-value"><%= fmtDate(data.valid_until) %></div>
            </div>
            <div class="ref-cell">
                <div class="ref-label">Agreement Date</div>
                <div class="ref-value"><%= fmtDate(data.createdAt) %></div>
            </div>
        </div>


        <!-- ══ PARTIES ══ -->
        <div class="party-section">

            <!-- BUYER -->
            <div class="party-box">
                <div class="party-box-title">Buyer</div>
                <div style="display: flex; gap: 12px; align-items: center; margin-bottom: 10px;">
                    <% const buyerImg = buyer?.profile_image || buyerNode?.image; %>
                    <% if (buyerImg) { %>
                        <img src="<%= buyerImg %>" style="width: 50px; height: 50px; border-radius: 4px; object-fit: cover; border: 1px solid #c8d4e8; background: #fff;" alt="" />
                    <% } else { %>
                        <div style="width: 50px; height: 50px; border-radius: 4px; background: #eef2f9; color: #1a3c6e; display: flex; align-items: center; justify-content: center; font-weight: bold; border: 1px solid #c8d4e8; font-size: 20px;">B</div>
                    <% } %>
                    <div style="flex: 1;">
                        <div class="party-name">
                            <%= buyer ? buyer.company_name : (data.buyer_tenant || '-') %>
                        </div>
                    </div>
                </div>
                <% if (buyerNode) { %>
                    <div class="party-meta">
                        <strong>Location:</strong> <%= buyerNode.location || '-' %>
                    </div>
                    <% if (buyerAddress) { %>
                        <div class="party-meta">
                            <strong>Address:</strong>
                            <%= buyerAddress.address || '' %>
                            <% if (buyerAddress.district) { %>, <%= buyerAddress.district.name %><% } %>
                            <% if (buyerAddress.state)    { %>, <%= buyerAddress.state.name    %><% } %>
                        </div>
                    <% } %>
                    <% if (buyerNode.gst_no) { %>
                        <div class="party-meta"><strong>GST No:</strong> <%= buyerNode.gst_no %></div>
                    <% } %>
                    <% if (buyerNode.license_no) { %>
                        <div class="party-meta"><strong>License No:</strong> <%= buyerNode.license_no %></div>
                    <% } %>
                <% } %>
                <% if (buyer && buyer.email) { %>
                    <div class="party-meta"><strong>Email:</strong> <%= buyer.email %></div>
                <% } %>
            </div>

            <!-- VENDOR -->
            <div class="party-box">
                <div class="party-box-title">Vendor / Supplier</div>
                <div style="display: flex; gap: 12px; align-items: center; margin-bottom: 10px;">
                    <% const vendorImg = vendor?.profile_image || vendorNode?.image; %>
                    <% if (vendorImg) { %>
                        <img src="<%= vendorImg %>" style="width: 50px; height: 50px; border-radius: 4px; object-fit: cover; border: 1px solid #c8d4e8; background: #fff;" alt="" />
                    <% } else { %>
                        <div style="width: 50px; height: 50px; border-radius: 4px; background: #eef2f9; color: #1a3c6e; display: flex; align-items: center; justify-content: center; font-weight: bold; border: 1px solid #c8d4e8; font-size: 20px;">V</div>
                    <% } %>
                    <div style="flex: 1;">
                        <div class="party-name">
                            <%= vendor ? vendor.company_name : (data.vendor_tenant || '-') %>
                        </div>
                    </div>
                </div>
                <% if (vendorNode) { %>
                    <div class="party-meta">
                        <strong>Location:</strong> <%= vendorNode.location || '-' %>
                    </div>
                    <% if (vendorAddress) { %>
                        <div class="party-meta">
                            <strong>Address:</strong>
                            <%= vendorAddress.address || '' %>
                            <% if (vendorAddress.district) { %>, <%= vendorAddress.district.name %><% } %>
                            <% if (vendorAddress.state)    { %>, <%= vendorAddress.state.name    %><% } %>
                        </div>
                    <% } %>
                    <% if (vendorNode.gst_no) { %>
                        <div class="party-meta"><strong>GST No:</strong> <%= vendorNode.gst_no %></div>
                    <% } %>
                    <% if (vendorNode.license_no) { %>
                        <div class="party-meta"><strong>License No:</strong> <%= vendorNode.license_no %></div>
                    <% } %>
                <% } %>
                <% if (vendor && vendor.email) { %>
                    <div class="party-meta"><strong>Email:</strong> <%= vendor.email %></div>
                <% } %>
            </div>

        </div>


        <!-- ══ 1. SCOPE OF AGREEMENT ══ -->
        <div class="section-title">1. Scope of Agreement</div>
        <div class="scope-paragraph">
            The Buyer agrees to purchase, and the Vendor agrees to supply, the following goods over the specified
            validity period at the locked Fixed Price. The Buyer will request actual deliveries incrementally via
            independent <strong>"Release Orders"</strong>. This Blanket Purchase Order is not an instruction to
            ship goods but a contractual commitment to the total quantities and prices listed herein.
        </div>


        <!-- ══ 2. CONTRACTED ITEMS ══ -->
        <div class="section-title">2. Contracted Items</div>
        <table class="items-table">
            <thead>
                <tr>
                    <th class="center" style="width: 36px;">S.No</th>
                    <th style="width: 35%;">Product Info</th>
                    <th>UOM</th>
                    <th>HSN Code</th>
                    <th class="right">Fixed Price (₹)</th>
                    <th class="right">Total Contracted Qty</th>
                    <th class="right">Total Value (₹)</th>
                </tr>
            </thead>
            <tbody>
                <% let computedGrandTotal = 0; %>
                <% data.blanketOrderItems.forEach(function(item, index) { %>
                    <%
                        const bp = item.buyerProduct  || {};
                        const vp = item.vendorProduct || {};
                        const lineValue = Number(item.total_contracted_qty || 0) * Number(item.unit_price || 0);
                        computedGrandTotal += lineValue;
                    %>
                    <tr>
                        <td class="center"><%= index + 1 %></td>

                        <!-- Product Info: Buyer SKU + Vendor Ref -->
                        <td>
                            <div class="product-name"><%= bp.name || '-' %></div>
                            <div class="product-buyer-sku">
                                Buyer SKU: <strong><%= bp.sku || '-' %></strong>
                                <% if (bp.barcode) { %> &nbsp;|&nbsp; Barcode: <%= bp.barcode %><% } %>
                            </div>
                            <div class="product-vendor-ref">
                                Vendor Ref: <strong><%= vp.name || '-' %></strong>
                                (<%= vp.sku || '-' %>)
                                <% if (vp.hsn_code) { %> &nbsp;|&nbsp; HSN: <%= vp.hsn_code %><% } %>
                            </div>
                        </td>

                        <!-- UOM -->
                        <td>
                            <% if (bp.measure) { %>
                                <%= bp.measure %> <%= bp.unit_type || '' %><br>
                                <span style="color:#888; font-size:10px;"><%= bp.package_type || '' %></span>
                            <% } else { %>-<% } %>
                        </td>

                        <!-- HSN -->
                        <td><%= vp.hsn_code || '-' %></td>

                        <!-- Fixed Price -->
                        <td class="right">₹ <%= fmtCurrency(item.unit_price) %></td>

                        <!-- Total Contracted Qty -->
                        <td class="right"><%= fmtCurrency(item.total_contracted_qty) %></td>

                        <!-- Total Value -->
                        <td class="right">₹ <%= fmtCurrency(lineValue) %></td>
                    </tr>
                <% }); %>

                <!-- Grand Total Row -->
                <tr class="grand-total-row">
                    <td colspan="5" style="text-align: right; padding-right: 12px;">
                        Total Estimated Contract Value:
                    </td>
                    <td colspan="2" class="right">₹ <%= fmtCurrency(computedGrandTotal) %></td>
                </tr>
            </tbody>
        </table>


        <!-- ══ 3. TERMS AND CONDITIONS ══ -->
        <div class="section-title">3. Terms and Conditions</div>
        <ol class="terms-list">
            <li>
                <strong>Price Lock:</strong>
                The Fixed Price agreed upon per unit shall remain locked for the entire validity period of this
                contract, regardless of market fluctuations, inflation, or currency changes. No unilateral
                revision of price shall be permitted without written consent from both parties.
            </li>
            <li>
                <strong>Release Orders:</strong>
                Goods will only be dispatched when the Buyer formally issues a <em>"Release Order"</em>
                specifying the target store or warehouse, the required delivery date, and the release quantity.
                No delivery shall be made without a valid Release Order reference.
            </li>
            <li>
                <strong>Invoicing:</strong>
                Final Tax Invoices will be generated individually against each Release Order upon dispatch.
                This Blanket Purchase Order does not constitute a tax invoice and will not be used for
                payment processing. Invoices must match the Release Order quantity and unit price herein.
            </li>
            <li>
                <strong>Validity:</strong>
                This BPO Agreement is valid from the date of signing until
                <strong><%= fmtDate(data.valid_until) %></strong>. Any unconsumed quantity
                at the end of the validity period shall lapse unless mutually extended in writing.
            </li>
            <li>
                <strong>Quality Assurance:</strong>
                The Vendor guarantees that all goods supplied under this agreement shall meet the agreed
                specifications, applicable food safety / quality standards, and shall have the minimum shelf
                life as specified in the product catalogue at the time of delivery.
            </li>
            <li>
                <strong>Dispute Resolution:</strong>
                Any disputes arising out of or relating to this agreement shall first be resolved through
                mutual negotiation. If unresolved within 30 days, the parties may seek mediation or
                legal recourse under applicable law.
            </li>
        </ol>


        <!-- ══ 4. AUTHORIZED SIGNATURES ══ -->
        <div class="section-title">4. Authorized Signatures</div>

        <div class="signature-section">
            <div class="signature-note">
                By signing below, both parties confirm that they have read, understood, and agree to the terms,
                prices, and quantities specified in this Blanket Purchase Order Agreement. This document is legally
                binding upon execution by duly authorized representatives of both parties.
            </div>

            <div class="signature-row">

                <!-- Buyer Signature -->
                <div class="signature-block">
                    <div class="signature-block-title">
                        For Buyer &mdash; <%= buyer ? buyer.company_name : (data.buyer_tenant || 'Buyer') %>
                    </div>
                    <div class="signature-line"></div>
                    <div class="signature-label">Authorized Signatory</div>

                    <div class="signature-label" style="margin-top: 10px;">Name:</div>
                    <div class="signature-field">&nbsp;</div>

                    <div class="signature-label" style="margin-top: 8px;">Designation:</div>
                    <div class="signature-field">&nbsp;</div>

                    <div class="signature-label" style="margin-top: 8px;">Date:</div>
                    <div class="signature-field">&nbsp;</div>

                    <% if (buyerNode && buyerNode.gst_no) { %>
                        <div class="party-meta" style="margin-top: 8px;">
                            <strong>GST No:</strong> <%= buyerNode.gst_no %>
                        </div>
                    <% } %>
                </div>

                <!-- Vendor Signature -->
                <div class="signature-block">
                    <div class="signature-block-title">
                        For Vendor / Supplier &mdash; <%= vendor ? vendor.company_name : (data.vendor_tenant || 'Vendor') %>
                    </div>
                    <div class="signature-line"></div>
                    <div class="signature-label">Authorized Signatory</div>

                    <div class="signature-label" style="margin-top: 10px;">Name:</div>
                    <div class="signature-field">&nbsp;</div>

                    <div class="signature-label" style="margin-top: 8px;">Designation:</div>
                    <div class="signature-field">&nbsp;</div>

                    <div class="signature-label" style="margin-top: 8px;">Date:</div>
                    <div class="signature-field">&nbsp;</div>

                    <% if (vendorNode && vendorNode.gst_no) { %>
                        <div class="party-meta" style="margin-top: 8px;">
                            <strong>GST No:</strong> <%= vendorNode.gst_no %>
                        </div>
                    <% } %>
                </div>

            </div>
        </div>


        <!-- ══ FOOTER ══ -->
        <div class="doc-footer">
            This is a system-generated Blanket Purchase Order Agreement &mdash;
            <strong><%= data.bpo_no %></strong>.
            Generated on <%= fmtDate(new Date()) %>.
            This document is confidential and intended solely for the named parties.
        </div>

    </div>
</body>

</html>
