<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Quotation #<%= data.reqNo %>
    </title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', Arial, Helvetica, sans-serif;
            font-size: 12px;
            color: #1a1f2e;
            background: #ffffff;
            line-height: 1.5;
        }

        .page {
            width: 100%;
            padding: 32px 36px;
        }

        /* ── TOP ACCENT BAR ── */
        .accent-bar {
            height: 5px;
            background: linear-gradient(90deg, #10b981 0%, #059669 50%, #34d399 100%);
            border-radius: 3px;
            margin-bottom: 28px;
        }

        /* ── HEADER ── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
        }

        .header-left .doc-title {
            font-size: 26px;
            font-weight: 700;
            color: #1e293b;
            letter-spacing: -0.5px;
        }

        .header-left .doc-number {
            font-size: 13px;
            color: #64748b;
            margin-top: 3px;
            font-weight: 500;
        }

        .header-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 8px;
        }

        /* ── STATUS BADGE ── */
        .status-badge {
            display: inline-block;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        .status-accept,
        .status-accepted,
        .status-confirmed {
            background: #dcfce7;
            color: #14532d;
            border: 1px solid #86efac;
        }

        .status-pending {
            background: #fef9c3;
            color: #854d0e;
            border: 1px solid #fde68a;
        }

        .status-reject,
        .status-rejected,
        .status-declined {
            background: #fee2e2;
            color: #7f1d1d;
            border: 1px solid #fca5a5;
        }

        .status-default {
            background: #e0f2fe;
            color: #0c4a6e;
            border: 1px solid #7dd3fc;
        }

        /* ── PARTY SECTION ── */
        .party-section {
            display: flex;
            gap: 20px;
            margin-bottom: 24px;
        }

        .party-box {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 18px 20px;
            background: #f8fafc;
        }

        .party-box-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #94a3b8;
            margin-bottom: 10px;
        }

        .party-name {
            font-size: 15px;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 6px;
        }

        .party-detail {
            font-size: 12px;
            color: #475569;
            margin-bottom: 4px;
        }

        .party-detail strong {
            color: #334155;
        }

        /* ── INFO GRID ── */
        .info-section {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 18px 20px;
            margin-bottom: 24px;
        }

        .info-section-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #94a3b8;
            margin-bottom: 14px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px 20px;
        }

        .info-item {}

        .info-label {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #94a3b8;
            margin-bottom: 2px;
        }

        .info-value {
            font-size: 12.5px;
            font-weight: 500;
            color: #1e293b;
        }

        /* ── ITEMS TABLE ── */
        .table-section-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #94a3b8;
            margin-bottom: 10px;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .items-table thead tr {
            background: #059669;
        }

        .items-table thead th {
            padding: 11px 12px;
            text-align: left;
            font-size: 10.5px;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .items-table thead th.right {
            text-align: right;
        }

        .items-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
        }

        .items-table tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        .items-table tbody tr:last-child {
            border-bottom: none;
        }

        .items-table tbody td {
            padding: 10px 12px;
            font-size: 11.5px;
            color: #334155;
            vertical-align: top;
        }

        .items-table tbody td.right {
            text-align: right;
            font-variant-numeric: tabular-nums;
            font-weight: 600;
            color: #1e293b;
        }

        .items-table tbody td.barcode {
            font-family: 'Courier New', monospace;
            font-size: 11.5px;
            color: #475569;
        }

        .product-title {
            font-weight: 600;
            color: #1e293b;
        }

        .product-sub {
            font-size: 10.5px;
            color: #64748b;
            margin-top: 2px;
        }

        /* ── TOTALS SECTION ── */
        .totals-section {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-top: 16px;
            margin-bottom: 30px;
        }

        .remarks-box {
            flex: 1;
            max-width: 50%;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px 16px;
            background: #f8fafc;
        }

        .remarks-title {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #94a3b8;
            margin-bottom: 6px;
        }

        .remarks-content {
            font-size: 11.5px;
            color: #475569;
            font-style: italic;
        }

        .totals-box {
            width: 280px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
        }

        .totals-table {
            width: 100%;
            border-collapse: collapse;
        }

        .totals-table td {
            padding: 8px 12px;
            font-size: 12px;
            color: #475569;
        }

        .totals-table tr:nth-child(even) {
            background: #f8fafc;
        }

        .totals-table tr.grand-total {
            border-top: 2px solid #e2e8f0;
            background: #e6f4ea;
        }

        .totals-table tr.grand-total td {
            font-size: 14px;
            font-weight: 700;
            color: #065f46;
        }

        /* ── BOTTOM NOTE ── */
        .bottom-note {
            margin-top: 30px;
            padding-top: 14px;
            border-top: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .bottom-note .doc-id {
            font-size: 10px;
            color: #94a3b8;
            font-weight: 500;
        }

        .bottom-note .generated {
            font-size: 10px;
            color: #cbd5e1;
        }
    </style>
</head>

<body>
    <div class="page">

        <!-- Accent Bar -->
        <div class="accent-bar"></div>

        <!-- Header -->
        <div class="header">
            <div class="header-left">
                <div class="doc-title">Quotation</div>
                <div class="doc-number"># <%= data.reqNo %>
                </div>
            </div>

            <div class="header-right">
                <% const status=(data.status || '' ).toLowerCase(); let statusClass='status-default' ; if
                    (status==='accept' || status==='accepted' || status==='confirmed' ) { statusClass='status-accept' ;
                    } else if (status==='pending' ) { statusClass='status-pending' ; } else if (status==='reject' ||
                    status==='rejected' || status==='declined' ) { statusClass='status-reject' ; } %>
                    <span class="status-badge <%= statusClass %>">
                        <%= data.status?.toUpperCase() %>
                    </span>
            </div>
        </div>

        <% // Resolve the active revision based on current_revision_no or fallback to the latest const
            activeRevision=data.quotationRevision?.find(r=> r.revision_no === data.current_revision_no)
            || data.quotationRevision?.[data.quotationRevision.length - 1]
            || {};
            const items = activeRevision.revisionItems || [];
            %>

            <!-- Party Section -->
            <div class="party-section">
                <!-- Vendor / Supplier Info -->
                <div class="party-box">
                    <div class="party-box-title">From (Supplier)</div>
                    <div class="party-name">
                        <%= data.meta?.name || data.meta?.nodeDetails?.name || data.meta?.businessNodeUser?.company_name
                            || '—' %>
                    </div>

                    <% if (data.meta?.nodeDetails?.address) { %>
                        <div class="party-detail">
                            <%= data.meta.nodeDetails.address.address || '' %>
                                <% if (data.meta.nodeDetails.address.district?.name) { %>
                                    , <%= data.meta.nodeDetails.address.district.name %>
                                        <% } %>
                                            <% if (data.meta.nodeDetails.address.state?.name) { %>
                                                , <%= data.meta.nodeDetails.address.state.name %>
                                                    <% } %>
                        </div>
                        <% } else if (data.meta?.nodeDetails?.location) { %>
                            <div class="party-detail">Location: <%= data.meta.nodeDetails.location %>
                            </div>
                            <% } %>

                                <% if (data.meta?.nodeDetails?.gst_no) { %>
                                    <div class="party-detail"><strong>GSTIN:</strong>
                                        <%= data.meta.nodeDetails.gst_no %>
                                    </div>
                                    <% } %>

                                        <% if (data.meta?.nodeDetails?.license_no) { %>
                                            <div class="party-detail"><strong>License No:</strong>
                                                <%= data.meta.nodeDetails.license_no %>
                                            </div>
                                            <% } %>

                                                <% if (data.meta?.businessNodeUser?.email) { %>
                                                    <div class="party-detail"><strong>Email:</strong>
                                                        <%= data.meta.businessNodeUser.email %>
                                                    </div>
                                                    <% } %>
                </div>

                <!-- Buyer Info -->
                <div class="party-box">
                    <div class="party-box-title">To (Buyer)</div>
                    <div class="party-name">
                        <%= data.buyerDetails?.name || data.buyerDetails?.nodeDetails?.name ||
                            data.buyerDetails?.businessNodeUser?.company_name || data.buyer_name || '—' %>
                    </div>

                    <% if (data.buyerDetails?.nodeDetails?.address) { %>
                        <div class="party-detail">
                            <%= data.buyerDetails.nodeDetails.address.address || '' %>
                                <% if (data.buyerDetails.nodeDetails.address.district?.name) { %>
                                    , <%= data.buyerDetails.nodeDetails.address.district.name %>
                                        <% } %>
                                            <% if (data.buyerDetails.nodeDetails.address.state?.name) { %>
                                                , <%= data.buyerDetails.nodeDetails.address.state.name %>
                                                    <% } %>
                        </div>
                        <% } else if (data.buyerDetails?.nodeDetails?.location) { %>
                            <div class="party-detail">Location: <%= data.buyerDetails.nodeDetails.location %>
                            </div>
                            <% } %>

                                <% if (data.buyerDetails?.nodeDetails?.gst_no) { %>
                                    <div class="party-detail"><strong>GSTIN:</strong>
                                        <%= data.buyerDetails.nodeDetails.gst_no %>
                                    </div>
                                    <% } %>

                                        <% if (data.buyerDetails?.nodeDetails?.license_no) { %>
                                            <div class="party-detail"><strong>License No:</strong>
                                                <%= data.buyerDetails.nodeDetails.license_no %>
                                            </div>
                                            <% } %>

                                                <% if (data.buyerDetails?.businessNodeUser?.email) { %>
                                                    <div class="party-detail"><strong>Email:</strong>
                                                        <%= data.buyerDetails.businessNodeUser.email %>
                                                    </div>
                                                    <% } %>

                                                        <% if (data.vendor_tenant && !data.buyerDetails) { %>
                                                            <div class="party-detail"><strong>Vendor Tenant ID:</strong>
                                                                <%= data.vendor_tenant %>
                                                            </div>
                                                            <% } %>
                </div>
            </div>

            <!-- Info Section -->
            <div class="info-section">
                <div class="info-section-title">Quotation Details</div>
                <div class="info-grid">

                    <div class="info-item">
                        <div class="info-label">RFQ Reference ID</div>
                        <div class="info-value">#<%= data.reqNo %>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Quoted On</div>
                        <div class="info-value">
                            <%= data.createdAt ? new Date(data.createdAt).toLocaleDateString("en-US", { year: "numeric"
                                , month: "long" , day: "numeric" }) : '—' %>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Valid Until</div>
                        <div class="info-value">
                            <%= data.valid_till ? new Date(data.valid_till).toLocaleDateString("en-US", {
                                year: "numeric" , month: "long" , day: "numeric" }) : '—' %>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">Active Revision</div>
                        <div class="info-value">Rev <%= activeRevision.revision_no || '—' %> (of <%=
                                    data.current_revision_no || '—' %>)</div>
                    </div>

                </div>
            </div>

            <!-- Items Table -->
            <div class="table-section-title">Line Items &mdash; <%= items.length || 0 %> item(s)</div>

            <table class="items-table">
                <thead>
                    <tr>
                        <!-- <th style="width: 28px;">#</th> -->
                        <th>Product Details (Vendor / Buyer)</th>
                        <th>Barcode</th>
                        <th>HSN</th>
                        <th>Pack Size</th>
                        <th class="right">Qty</th>
                        <th class="right">Offer Price (₹)</th>
                        <th class="right">Line Total (₹)</th>
                    </tr>
                </thead>

                <tbody>
                    <% let calculatedSubTotal=0; items.forEach((item, index)=> {
                        const qty = Number(item.qty || 0);
                        const price = Number(item.offer_price || 0);
                        const lineTotal = qty * price;
                        calculatedSubTotal += lineTotal;
                        %>
                        <tr>
                            <!-- <td><span style="color: #cbd5e1; font-size: 10px; font-weight: 700;"><%= index + 1 %></span></td> -->
                            <td>
                                <div class="product-title">
                                    <% if (item.vendorProduct?.name) { %>
                                        Vendor: <%= item.vendorProduct.name %>
                                            <% } else { %>
                                                Vendor: —
                                                <% } %>
                                </div>
                                <div class="product-sub">
                                    <% if (item.vendorProduct?.sku) { %>
                                        SKU: <%= item.vendorProduct.sku %>
                                            <% } %>
                                </div>

                                <div class="product-title" style="margin-top: 4px;">
                                    <% if (item.buyerProduct?.name) { %>
                                        Buyer: <%= item.buyerProduct.name %>
                                            <% } else { %>
                                                Buyer: —
                                                <% } %>
                                </div>
                                <div class="product-sub">
                                    <% if (item.buyerProduct?.sku) { %>
                                        SKU: <%= item.buyerProduct.sku %>
                                            <% } %>
                                </div>
                            </td>
                            <td class="barcode">
                                <div>V: <%= item.vendorProduct?.barcode || '—' %>
                                </div>
                                <div style="margin-top: 4px;">B: <%= item.buyerProduct?.barcode || '—' %>
                                </div>
                            </td>
                            <td>
                                <div>V: <%= item.vendorProduct?.hsn_code || '—' %>
                                </div>
                                <div style="margin-top: 4px;">B: <%= item.buyerProduct?.hsn_code || '—' %>
                                </div>
                            </td>
                            <td>
                                <% if (item.vendorProduct?.measure) { %>
                                    <%= item.vendorProduct.measure %>
                                        <%= item.vendorProduct.unit_type || '' %>
                                            <% } else if (item.buyerProduct?.measure) { %>
                                                <%= item.buyerProduct.measure %>
                                                    <%= item.buyerProduct.unit_type || '' %>
                                                        <% } else { %>
                                                            —
                                                            <% } %>
                            </td>
                            <td class="right">
                                <%= qty.toFixed(2) %>
                            </td>
                            <td class="right">
                                <%= price.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2
                                    }) %>
                            </td>
                            <td class="right">
                                <%= lineTotal.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits:
                                    2 }) %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>

            <!-- Totals & Remarks -->
            <div class="totals-section">
                <!-- Remarks -->
                <div class="remarks-box">
                    <div class="remarks-title">Remarks</div>
                    <div class="remarks-content">
                        <%= activeRevision.remarks || 'No remarks provided.' %>
                    </div>
                </div>

                <!-- Totals -->
                <div class="totals-box">
                    <table class="totals-table">
                        <tr>
                            <td>Sub Total:</td>
                            <td class="right">₹ <%= calculatedSubTotal.toLocaleString("en-IN", { minimumFractionDigits:
                                    2, maximumFractionDigits: 2 }) %>
                            </td>
                        </tr>
                        <tr class="grand-total">
                            <td>Grand Total:</td>
                            <td class="right">₹ <%= Number(activeRevision.grand_total ||
                                    calculatedSubTotal).toLocaleString("en-IN", { minimumFractionDigits: 2,
                                    maximumFractionDigits: 2 }) %>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Bottom Note -->
            <div class="bottom-note">
                <div class="doc-id">QTN &bull; RFQ #<%= data.reqNo %> &bull; Warehouse Management System</div>
                <div class="generated">Generated: <%= new Date().toLocaleString("en-US", { dateStyle: "medium" ,
                        timeStyle: "short" }) %>
                </div>
            </div>

    </div>
</body>

</html>